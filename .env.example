# OrbitalShield — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA versione o .env com valores preenchidos

# Banco de dados
# db/connection.py lê DATABASE_URL. Para SQLite local, mantenha este padrão.
DATABASE_URL=sqlite:///./orbitalshield.db

# MQTT — broker de desenvolvimento (sem autenticação)
MQTT_BROKER=test.mosquitto.org
MQTT_PORT=1883
MQTT_CLIENT_ID=orbitalshield_bridge_01
# Tópicos usados pelo ESP32 e pela bridge:
# - orbitalshield/alerts
# - orbitalshield/esp32/telemetry
# Observação: na versão atual, esses tópicos são constantes em ingestion/mqtt_telemetry.py
# e esp32/orbital_shield.ino; altere o código se precisar mudar os nomes.

# MQTT — autenticação (produção com TLS, porta 8883)
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_PORT=8883

# OMNIWeb / NOAA
OMNIWEB_BASE_URL=https://omniweb.gsfc.nasa.gov/cgi/nx1.cgi

# Streamlit
STREAMLIT_SERVER_PORT=8501
