# OrbitalShield — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA versione o .env com valores preenchidos

# Banco de dados
DB_PATH=orbitalshield.db

# MQTT — broker de desenvolvimento (sem autenticação)
MQTT_BROKER=test.mosquitto.org
MQTT_PORT=1883
MQTT_CLIENT_ID=orbitalshield_bridge_01
MQTT_TOPIC_TELEMETRY=orbitalshield/esp32/telemetry
MQTT_TOPIC_ALERT=orbitalshield/alerts

# MQTT — autenticação (produção com TLS, porta 8883)
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_PORT=8883

# OMNIWeb / NOAA
OMNIWEB_BASE_URL=https://omniweb.gsfc.nasa.gov/cgi/nx1.cgi

# Streamlit
STREAMLIT_SERVER_PORT=8501